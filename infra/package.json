    "destroy": "cdk destroy --all",
    "lint": "eslint lib --ext .ts"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.147.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "aws-cdk": "^2.147.0",
    "typescript": "^5.9.3"
  }
}
