# AWS
AWS_REGION=eu-west-1

# Cognito (from CDK outputs after deploy)
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# SNS topic for push notifications
SNS_TOPIC_ARN=arn:aws:sns:eu-west-1:123456789012:rallyhub-notifications-staging

# DynamoDB table names (defaults match CDK stack; override for local testing)
TABLE_USERS=rallyhub-users
TABLE_CLUBS=rallyhub-clubs
TABLE_MEMBERSHIPS=rallyhub-memberships
TABLE_SESSIONS=rallyhub-sessions
TABLE_SCHEDULES=rallyhub-schedules
TABLE_LEDGER=rallyhub-ledger
TABLE_TOURNAMENTS=rallyhub-tournaments
TABLE_DECLARATIONS=rallyhub-declarations
TABLE_PAYMENTS=rallyhub-payments
TABLE_ANNOUNCEMENTS=rallyhub-announcements
TABLE_JOIN_REQUESTS=rallyhub-join-requests
