{
  "compilerOptions": {
    "target":            "ESNext",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ESNext", "DOM"],
    "jsx":               "react-native",
    "strict":            true,
    "skipLibCheck":      true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit":            true,
    "baseUrl":           ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "ios",
    "android",
    ".expo"
  ]
}
