{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build":      { "dependsOn": ["^build"], "outputs": ["dist/**", "build/**", "build/libs/**", "build/function.zip"], "cache": true },
    "native":     { "dependsOn": ["build"],  "outputs": ["build/native/**", "build/function.zip"], "cache": true },
    "test":       { "dependsOn": ["^build"], "outputs": ["build/reports/**", "coverage/**"], "cache": true },
    "lint":       { "outputs": [], "cache": true },
    "type-check": { "dependsOn": ["^build"], "outputs": [], "cache": true },
    "synth":      { "dependsOn": ["^build"], "outputs": ["cdk.out/**"], "cache": true },
    "deploy":     { "dependsOn": ["build", "synth"], "cache": false },
    "dev":        { "cache": false, "persistent": true },
    "clean":      { "cache": false }
  }
}
